" nnoremap { {zz
" nnoremap } }zz

" #==============================[Lines]==============================#
" Hybrid line numbers
set number! relativenumber!

" Highlight current line
set cursorline
hi CursorLine cterm=NONE ctermbg=0 guibg=lightgrey

" Only highlight in active window
augroup CursorLineOnlyInActiveWindow
    autocmd!
    autocmd VimEnter,WinEnter,BufWinEnter * setlocal cursorline
    autocmd WinLeave * setlocal nocursorline
augroup END

set laststatus=2

" Show tabs as › and trailing whitespace as •
set list
set listchars=tab:›\ ,trail:•,extends:#,nbsp:.

" Remove trailing whitespace
command RemoveTrailingWhitespace :%s/\s\+$//

" Comments do not wrap when hitting enter
set formatoptions-=cro

" Fold using indentation
set foldmethod=syntax

" All folds open
set foldlevelstart=99

" #==============================[Search]==============================#
" Enable search highlighting
set hlsearch
" Enable incremental search
set incsearch

" Keep searches in the middle of the screen
nnoremap n nzz
nnoremap N Nzz

" Center search on <ENTER>
function! CenterSearch()
  let cmdtype = getcmdtype()
  if cmdtype == '/' || cmdtype == '?'
    return "\<enter>zz"
  endif
  return "\<enter>"
endfunction

cnoremap <silent> <expr> <enter> CenterSearch()

" Turn off search highlighting
nnoremap <leader>/ :nohlsearch<cr>

" Ignore case when searching lowercase
set ignorecase

" Don't ignore case when searching uppercase
set smartcase

" Quick search and replace ("." to confirm, "n" to skip)
nnoremap c* /\<<C-R>=expand('<cword>')<CR>\>\C<CR>``cgn
nnoremap c# ?\<<C-R>=expand('<cword>')<CR>\>\C<CR>``cgN

" #==============================[Tabs/Spaces]==============================#
" Tab becomes 4 spaces
set tabstop=4

" Indents are 4 spaces
set shiftwidth=4

" Tab and backspace deletes 4 spaces
set softtabstop=4

" Spaces instead of tab characters
set expandtab

" If at the beginning of a line, go to the next indent when tab is pressed
set smarttab

" #==============================[Windows]==============================#
" More natural splitting
set splitright splitbelow

" Easier moving between windows
nnoremap <C-h> <C-w>h
nnoremap <C-j> <C-w>j
nnoremap <C-k> <C-w>k
nnoremap <C-l> <C-w>l

" Mark two windows (MarkA/B) then swap with :SwapWindows
command! -bar MarkA :let WinNumA = winnr() | let WinBufA = bufnr("%")
command! -bar MarkB :let WinNumB = winnr() | let WinBufB = bufnr("%")

" Swap windows marked A and B
function! SwapAB()
  exec  g:WinNumA . " wincmd w" ."|".
      \ "buffer ". g:WinBufB ."|".
      \ g:WinNumB ." wincmd w" ."|".
      \ "buffer ". g:WinBufA
  let l:tmp = g:WinNumA
  let g:WinNumA = g:WinNumB
  let g:WinNumB = l:tmp
endfunction

command! SwapWindows :call SwapAB()

