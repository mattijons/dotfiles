" #==============================[Mappings]==============================#
" Unmap Ex mode while in normal mode
nmap Q <Nop>

" Set leader to space
let mapleader=" "

" Quick copy
nmap <Leader>y yiw

" Quick replace word with paste
nmap <Leader>r viwp

" Quick save (write)
nmap <Leader>w :w<CR>

" Copy from cursor to end of line
nmap Y y$

" Reselect entered text
nnoremap gV `[v`]

" Duplicates then regains selection
vmap Y y`>pgv

" Gitgutter hunk movement refocus
nmap ]c <Plug>(GitGutterNextHunk) zz
nmap [c <Plug>(GitGutterPrevHunk) zz

" Toggle gitgutter
nnoremap <leader>gt :GitGutterToggle<cr>

" #==============================[Movement]==============================#
